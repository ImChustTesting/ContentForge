# ContentForge — environment variables
#
# Copy this file to `.env` and fill in the three required values below.
# Generate the random ones with the commands shown.

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# Postgres password. Any string; pick something random.
# generate with:  openssl rand -hex 16
POSTGRES_PASSWORD=

# Session cookie signing secret. 32+ random bytes.
# generate with:  openssl rand -hex 32
SESSION_SECRET=

# Master key for AES-256-GCM encryption of your Anthropic API key at rest.
# MUST be exactly 64 hex characters (= 32 bytes). Do not change after first use
# without running the rotation script (see SECURITY.md).
# generate with:  openssl rand -hex 32
ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL
# ---------------------------------------------------------------------------

# Port the dashboard binds to on the host. Default 3000.
APP_PORT=3000

# Concurrency for ffmpeg-heavy stages. Defaults shown.
WORKER_CONCURRENCY_EDIT=2
WORKER_CONCURRENCY_REFRAME=1

# x264 preset for the final encode. Trades speed vs. file size.
#   veryfast = OSS default; ~3x faster than medium, visually fine for short-form
#   medium   = original quality target
#   slow     = best quality, very slow on 4-core CPUs
ENCODE_PRESET=veryfast

# Whisper model. base | small | medium. Larger = better transcript, slower.
WHISPER_MODEL=small

# Hard cap on source video length in minutes. 30 is the v1 default.
MAX_SOURCE_MINUTES=30

# Set to "true" only if you put ContentForge behind a reverse proxy that
# terminates HTTPS. Required for secure cookies to be sent.
BEHIND_TLS=false

# Log verbosity. debug | info | warn | error
LOG_LEVEL=info

# Image tag to pull / build. Leave blank for `latest`.
VERSION=latest
