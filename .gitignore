# =============================================================================
# Secrets — never commit
# =============================================================================
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/

# =============================================================================
# Runtime data — never commit
# =============================================================================
data/
uploads/
clips/
captions/
edited/
thumbs/
work/
*.mp4
*.mov
*.mkv
*.webm
*.wav
*.mp3
*.aac
*.srt
*.ass
*.vtt
# Allow a packaged demo if we ever ship one under docs/
!docs/**/*.mp4
!docs/**/*.gif
# Allow the smoke-test fixture instructions file (no media committed)
!worker/test/fixtures/README.md

